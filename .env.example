
---

## File: `clispconnect/.env.example`

```bash
# ===========================================
# CLISPConnect Environment Variables
# ===========================================

# Application
APP_NAME=CLISPConnect API
APP_VERSION=1.0.0
DEBUG=false

# Database
DATABASE_URL=postgresql://clispuser:password@localhost:5432/clispconnect
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=https://www.clispconnect.com,https://api.clispconnect.com,http://localhost:3000,http://localhost:8000

# File Storage
STORAGE_BUCKET=clispconnect-storage
MAX_UPLOAD_SIZE=10485760

# Email (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@clispconnect.com

# Pilot Configuration
PILOT_DISTRICT_ID=11111111-1111-1111-1111-111111111111
PILOT_START_DATE=2026-01-01
PILOT_END_DATE=2026-06-30

# Google Cloud (for deployment)
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1